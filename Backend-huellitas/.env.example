# ── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=3001                     # Puerto donde corre el backend
DOMAIN_FRONTEND=*             # Origen permitido por CORS. En prod: https://tu-dominio.com
SHOW_ENV=false                # Muestra las variables de entorno al iniciar (debug)
PRINT_LOGS=false              # Habilita logs detallados en consola

# ── Modo Dios (solo desarrollo) ───────────────────────────────────────────────
# Si es 'true', desactiva la seguridad e inyecta un usuario Admin por defecto
MODO_DIOS=false

# ── Base de datos (PostgreSQL / Supabase) ─────────────────────────────────────
DB_TYPE=postgres
DB_HOST=localhost                        # En Supabase: db.<project-ref>.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_NAME=db-huellitas                     # En Supabase: postgres
DB_PASSWORD=tu_password_aqui
DB_LOGS=false                            # Muestra las queries SQL en consola

# ── JWT ───────────────────────────────────────────────────────────────────────
ACTIVE_JWT=true
JWT_SECRET=cambia_esto_por_una_clave_larga_y_segura
JWT_TIME_EXPIRE=1h                       # Tiempo de expiración del token

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
# Crea una cuenta en https://twilio.com y activa el Sandbox de WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Número del sandbox de Twilio

# ── Email (Gmail con App Password) ───────────────────────────────────────────
# Genera un App Password en: https://myaccount.google.com → Seguridad → Contraseñas de aplicaciones
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx          # App Password de 16 caracteres (con espacios)
EMAIL_FROM="Huellitas Digitales <tu_correo@gmail.com>"

# ── Notificaciones Admin ──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@tudominio.com         # Recibe alertas de stock bajo y reportes

# ── Gemini API (Bot conversacional) ──────────────────────────────────────────
# Obtén tu API Key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ── Bot API Key ───────────────────────────────────────────────────────────────
# Clave compartida entre el backend y n8n para autenticar el bot
# Genera una clave segura con: openssl rand -hex 32
BOT_API_KEY=genera_una_clave_aleatoria_larga_aqui
